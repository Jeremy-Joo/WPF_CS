<Window x:Class="TekkenStats.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tekken Record Maker" Height="780" Width="660"
        Icon="jack.ico"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0 source -->
            <RowDefinition Height="Auto"/>
            <!-- 1 ids -->
            <RowDefinition Height="Auto"/>
            <!-- 2 date -->
            <RowDefinition Height="Auto"/>
            <!-- 3 settings -->
            <RowDefinition Height="Auto"/>
            <!-- 4 run -->
            <RowDefinition Height="Auto"/>
            <!-- 5 progress -->
            <RowDefinition Height="*"/>
            <!-- 6 log -->
            <RowDefinition Height="Auto"/>
            <!-- 7 footer -->
        </Grid.RowDefinitions>

        <!-- 0. 데이터 소스 (EWGF 전용) -->
        <GroupBox Grid.Row="0" Header="데이터 소스" Padding="8" Margin="0,0,0,8">
            <TextBlock Text="EWGF (퀵·랭크·방·그룹, 날짜 필터 가능)" VerticalAlignment="Center"/>
        </GroupBox>

        <!-- 1. 식별코드 -->
        <GroupBox Grid.Row="1" Header="식별코드 (한 줄에 하나, 또는 콤마로 구분)" Padding="8" Margin="0,0,0,8">
            <TextBox x:Name="txtIds" Height="70" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" FontFamily="Consolas"
                     Text="53deQ2dmLday"/>
        </GroupBox>

        <!-- 2. 기간 -->
        <GroupBox x:Name="grpDate" Grid.Row="2" Header="기간" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <CheckBox x:Name="chkAll" Content="전체 기간 (ALL)" IsChecked="True"
                          Checked="OnAllChanged" Unchecked="OnAllChanged" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="시작:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker x:Name="dpStart" Width="140" IsEnabled="False"/>
                    <TextBlock Text="끝:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <DatePicker x:Name="dpEnd" Width="140" IsEnabled="False"/>
                </StackPanel>
                <TextBlock x:Name="txtDateNote" Foreground="Gray" Margin="0,6,0,0"
                           Text="전체 기간(ALL) 체크를 끄면 시작~끝 날짜로 필터합니다."/>
            </StackPanel>
        </GroupBox>

        <!-- 3. 설정 -->
        <GroupBox Grid.Row="3" Header="설정" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="결과 폴더:" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox x:Name="txtOutDir" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                         Text="D:\TekkenResult\User"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="브라우저 프로필:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="txtProfile" Grid.Row="1" Grid.Column="1"
                         Text="D:\TekkenResult\.browser_profile"/>
            </Grid>
        </GroupBox>

        <!-- 4. 실행 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="btnRun" Content="수집 시작" Width="120" Height="34"
                    FontWeight="Bold" Click="OnRun"/>
            <Button x:Name="btnCancel" Content="중지" Width="80" Height="34" Margin="8,0,0,0"
                    IsEnabled="False" Click="OnCancel"/>
            <Button x:Name="btnOpen" Content="결과 폴더 열기" Width="120" Height="34" Margin="8,0,0,0"
                    Click="OnOpenFolder"/>
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="14,0,0,0"
                       Text="대기 중"/>
        </StackPanel>

        <!-- 5. 진행률 -->
        <ProgressBar x:Name="prog" Grid.Row="5" Height="6" IsIndeterminate="False" Margin="0,0,0,8"/>

        <!-- 6. 로그 -->
        <GroupBox Grid.Row="6" Header="로그">
            <TextBox x:Name="txtLog" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                     HorizontalScrollBarVisibility="Auto" Background="#111" Foreground="#DDD"/>
        </GroupBox>

        <!-- 7. 제작자 (눈에 띄지 않는 하단 우측) -->
        <TextBlock Grid.Row="7" HorizontalAlignment="Right" Margin="0,5,2,0"
                   Foreground="#9AA0A6" FontSize="10"
                   ToolTip="제작: JackFather (jinho.ju@live.com)"
                   Text="JackFather · jinho.ju@live.com"/>
    </Grid>
</Window>
